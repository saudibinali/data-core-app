# ─────────────────────────────────────────────────────────────────────────────
# Internal Operations Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Use a connection pooler (PgBouncer) in production.
DATABASE_URL=postgresql://opsuser:changeme@localhost:5432/opsplatform

# ── Authentication (JWT) ─────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret: openssl rand -hex 64
# Production: API refuses startup if JWT_SECRET is missing or weak (< 32 chars).
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# ── Security (F1) ────────────────────────────────────────────────────────────
# Set to false only for temporary rollback of rate limits / strict CORS / webhooks.
# SECURITY_STRICT=true

# ── Leave canonical cutover (F5.2) ───────────────────────────────────────────
# LEAVE_CANONICAL_WRITE=false  → rollback to legacy hr_employee_leaves writes
# CANONICAL_LEAVE_SUBMIT=true
# CANONICAL_LEAVE_APPROVE=true
# CANONICAL_LEAVE_READ=true
# LEGACY_LEAVE_FREEZE=true
# LEAVE_CUTOVER_PILOT_WORKSPACE_ID=1

# ── Org canonical cutover (F5.1) ─────────────────────────────────────────────
# Freeze legacy department writes for pilot workspace; manage structure in hr_org_units.
# ORG_CUTOVER=false
# ORG_CUTOVER_PILOT_WORKSPACE_ID=1
# PLATFORM_STABILIZATION_ALL_WORKSPACES=false

# ── Payroll canonical cutover (F6.1) ─────────────────────────────────────────
# PAYROLL_CANONICAL_WRITE=false  → rollback to legacy hr_payroll_runs UI/writes
# LEGACY_PAYROLL_FREEZE=true     → 410 on legacy POST/PATCH/process payroll runs
# PAYROLL_CUTOVER_PILOT_WORKSPACE_ID=1

# ── Attendance canonical cutover (F6.2) ──────────────────────────────────────
# ATTENDANCE_CANONICAL_WRITE=false → rollback manual legacy hr_attendance writes
# LEGACY_ATTENDANCE_FREEZE=true     → 410 on legacy POST/PATCH/bulk/import
# ATTENDANCE_CUTOVER_PILOT_WORKSPACE_ID=1

# ── Payslip PDF (F6.3) ───────────────────────────────────────────────────────
# PAYSLIP_DOWNLOAD_TTL_SEC=900

# ── Event outbox (F7.2) ───────────────────────────────────────────────────────
# EVENT_OUTBOX_PUBLISH_MODE=direct|shadow|outbox  (default direct)
# EVENT_OUTBOX_DRAIN=true   → poll outbox (required when mode=outbox)
# EVENT_OUTBOX_POLL_MS=5000

# ── Observability (F8) ───────────────────────────────────────────────────────
# METRICS_ENABLED=false  → disable GET /health/metrics (Prometheus text)

# ── Performance & scale (F9–F10) ─────────────────────────────────────────────
# WORKER_MODE=embedded|api|worker   (default embedded = HTTP + background in one process)
# REPORT_ASYNC_ROW_THRESHOLD=1000   → HR roster export goes async above this row count
# DATABASE_READ_URL=postgresql://...  → optional read replica for reports/dashboards
# REDIS_URL=redis://localhost:6379    → optional cache / future rate-limit store
# S3_ENDPOINT=https://minio.example.com
# S3_BUCKET=ops-attachments
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true

# ── Integrity CI gates (F6.4) ────────────────────────────────────────────────
# WORKSPACE_ID=1 DATABASE_URL=... pnpm run validate:canonical-cutover
# FAIL_ON_WARN=1  → treat warnings as exit 1

# ── Tenant isolation / RBAC (F2) ───────────────────────────────────────────
# Strict workspace RBAC: admin/manager use role bundles instead of implicit bypass.
# WORKSPACE_RBAC_STRICT=false
# Enforce PostgreSQL RLS pilot (requires migration 0034 + app.current_workspace_id).
# WORKSPACE_RLS_ENFORCE=false

# ── Application ──────────────────────────────────────────────────────────────
APP_URL=https://your-domain.com
NODE_ENV=production
PORT=8080

# ── Object Storage ───────────────────────────────────────────────────────────
# Replit Object Storage bucket (or S3-compatible)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-another-long-random-string

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Optional — if not set, invitation emails are silently skipped.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=notifications@example.com
SMTP_SECURE=false

# Contact form inbox (server-only; never shown in the UI). Defaults to SMTP_USER if unset.
CONTACT_INBOX_EMAIL=enterprise-inbox@example.com

# Test platform SMTP (super admin): POST /api/platform/smtp/test after restart

# ── Platform Owner Bootstrap ─────────────────────────────────────────────────
# Used by: pnpm --filter @workspace/scripts run setup-owner
# You can also run the script interactively without these vars.
OWNER_EMPLOYEE_NUMBER=ADMIN001
OWNER_NAME=Platform Admin
OWNER_EMAIL=admin@example.com
OWNER_PASSWORD=change-me-strong-password
